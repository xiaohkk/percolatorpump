# Solana
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
# Populated after task #17 (devnet deploy). Mainnet gets its own value post-cutover.
NEXT_PUBLIC_PERCOLATOR_PROGRAM_ID=
NEXT_PUBLIC_ORACLE_PROGRAM_ID=
TREASURY_WALLET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Vanity pool
VANITY_POOL_ENCRYPTION_KEY=
VANITY_POP_SECRET=

# PumpPortal
PUMPPORTAL_API_URL=https://pumpportal.fun/api

# Phase 2 unlock (set to "true" after mainnet CreateSlab + BootstrapLp run)
NEXT_PUBLIC_PHASE_2_LIVE=false

# Paid-listing tiered pricing (task #23 v2). The on-chain program only
# enforces a 0.5 SOL floor; these envs drive the frontend gate that
# decides which tier applies based on how many ORIGIN_OPEN slabs already
# exist. Edit freely for promos/price hikes — no program upgrade needed.
NEXT_PUBLIC_PROMO_MARKET_COUNT=10
NEXT_PUBLIC_PROMO_LISTING_FEE_SOL=0.5
NEXT_PUBLIC_STANDARD_LISTING_FEE_SOL=1.5
